{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npm run build && node dist/main.js",
    "dev:watch": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "test:e2e": "jest --config ./jest.config.js --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/swagger": "^11.0.6",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^6.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "docx": "^9.6.1",
    "express": "^5.1.0",
    "mammoth": "^1.9.1",
    "multer": "^1.4.5-lts.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.14",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^6.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
